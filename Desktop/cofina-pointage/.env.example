APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR
# Fuseau horaire de l'application (heure locale Sénégal). Ex. Europe/Paris pour la France.
APP_TIMEZONE=Africa/Dakar

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug


DB_CONNECTION=sqlite
# Chemin du fichier SQLite (relatif à la racine du projet ou absolu)
DB_DATABASE=database/database.sqlite
# DB_FOREIGN_KEYS=true

# --- MySQL (décommenter pour repasser sur MySQL) ---
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=lpointage
# DB_USERNAME=root
# DB_PASSWORD=

# --- Proxy Oracle (Python) : recommandé si PHP n’a pas oci8 ---
# Laravel appelle ce service HTTP ; Python utilise oracledb + Instant Client.
# SIG_ORACLE_HTTP_ENABLED=true
# SIG_ORACLE_HTTP_BASE_URL=http://127.0.0.1:8810
# SIG_ORACLE_HTTP_TOKEN=
# SIG_ORACLE_HTTP_TIMEOUT=30
# SIG_ORACLE_HTTP_VERIFY_SSL=true
# SIG_ORACLE_HTTP_LOOKUP_PERSONNEL_PATH=/api/sig/lookup-personnel
# SIG_ORACLE_HTTP_STAFF_LIEES_PATH=/api/sig/staff/{matricule}/personnes-liees

# Oracle REPORT_GROUPE — utilisé par le proxy Python (.env chargé depuis scripts/oracle-proxy-python)
# et optionnellement par PHP si oci8 + ORACLE_REPORT_GROUPE_LOOKUP_ENABLED
# ORACLE_REPORT_GROUPE_HOST=
# ORACLE_REPORT_GROUPE_PORT=1521
# ORACLE_REPORT_GROUPE_SERVICE_NAME=
# ORACLE_REPORT_GROUPE_USERNAME=
# ORACLE_REPORT_GROUPE_PASSWORD=
# ORACLE_REPORT_GROUPE_LOOKUP_ENABLED=false
# ORACLE_REPORT_GROUPE_LOOKUP_PERSONNEL_SQL=
# ORACLE_REPORT_GROUPE_STAFF_LIEES_SQL=
# Schéma Oracle (proxy Python) — ex. CFSFCUBS145
# ORACLE_CURRENT_SCHEMA=CFSFCUBS145
# Fichiers SQL (scripts/oracle-proxy-python/sql/) si vous ne mettez pas le SQL en une ligne dans .env
# ORACLE_LOOKUP_PERSONNEL_SQL_FILE=sql/kyc_by_customer.sql
# ORACLE_ENCOURS_SQL_FILE=sql/encours_client.sql

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# database = jobs en BDD, à traiter avec: php artisan queue:work
# sync = envoi immédiat (pas de worker nécessaire, utile en dev)
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Avances sur salaire — intégration RH : local = écritures en base AppCofina ;
# external = POST JSON vers une autre application (Bearer token).
# AVANCE_SALAIRE_INTEGRATION_MODE=local
# AVANCE_SALAIRE_INTEGRATION_EXTERNAL_BASE_URL=https://integrations.example.com
# AVANCE_SALAIRE_INTEGRATION_EXTERNAL_PATH=/api/integrations/avances-salaire
# AVANCE_SALAIRE_INTEGRATION_EXTERNAL_TOKEN=
# AVANCE_SALAIRE_INTEGRATION_EXTERNAL_TIMEOUT=30
# AVANCE_SALAIRE_INTEGRATION_EXTERNAL_VERIFY_SSL=true
# Si external : dupliquer aussi les lignes en local (transition / audit)
# AVANCE_SALAIRE_INTEGRATION_EXTERNAL_MIRROR_LOCAL=false

# Envoi des e-mails
# — log : aucun envoi réel (message + code OTP dans storage/logs/laravel.log)
# — smtp + Mailtrap (dev) : https://mailtrap.io → Inbox → SMTP Settings
#     MAIL_HOST=sandbox.smtp.mailtrap.io  MAIL_PORT=2525  MAIL_USERNAME=…  MAIL_PASSWORD=…
# — smtp : le serveur MUST correspond au fournisseur du compte MAIL_USERNAME :
#     • @gmail.com → MAIL_HOST=smtp.gmail.com (jamais smtp.office365.com)
#     • compte Microsoft / @entreprise.fr → MAIL_HOST=smtp.office365.com
#   Sinon Outlook renvoie 535 même avec le « bon » mot de passe.
# — Gmail : créer un « mot de passe d’application » (16 car.) dans le compte Google.
# Erreur « 535 Authentication unsuccessful » = mauvais couple hôte/compte, mot de passe, ou 2FA sans mot de passe d’application.
# Secours local si SMTP échoue : code OTP écrit dans laravel.log (POINTAGE_OTP_EMAIL_FALLBACK_LOG=true par défaut en local)
# API mobile : en local, POST /api/login renvoie aussi debug_otp (POINTRUST_DEBUG_OTP_IN_LOGIN)
# Si QUEUE_CONNECTION=database, lancez un worker : php artisan queue:work
#MAIL_MAILER=log
#MAIL_HOST=sandbox.smtp.mailtrap.io3
#MAIL_PORT=2525
#MAIL_USERNAME=yacin36juz@gmail.com
#MAIL_PASSWORD=5556yacin#
#MAIL_ENCRYPTION=tls
#MAIL_FROM_ADDRESS=noreply@pointrust.local
#MAIL_FROM_NAME="POINTRUST"


# SMTP Office 365 — COFIRH (mot de passe dans .env local uniquement, ne pas committer)
MAIL_MAILER=smtp
MAIL_HOST=smtp.office365.com
MAIL_PORT=587
MAIL_USERNAME=report.sn@cofinacorp.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=report.sn@cofinacorp.com
MAIL_FROM_NAME="COFIRH"
# Décommenter pour Mailtrap (e-mails visibles dans le dashboard, pas dans la boîte réelle) :
# MAIL_MAILER=smtp
# MAIL_HOST=sandbox.smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USERNAME=votre_user_mailtrap
# MAIL_PASSWORD=votre_pass_mailtrap
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS=noreply@pointrust.com
# MAIL_FROM_NAME="POINTRUST"
# POINTRUST_DEBUG_OTP_IN_LOGIN=true
# Exemple Gmail réel (décommentez et remplissez) :
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=votre-compte@gmail.com
# MAIL_PASSWORD=mot-de-passe-application-16-caracteres
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS=votre-compte@gmail.com

# --- Pointage : OTP par SMS (Twilio) ---
# En dev : POINTAGE_OTP_SMS_DRIVER=log (aucun SMS réel, trace dans storage/logs)
# En prod : twilio + identifiants Twilio (compte sur https://www.twilio.com)
 POINTAGE_OTP_SMS_ENABLED=true
 POINTAGE_OTP_SMS_DRIVER=log
 #Indicatif par défaut si le profil a un numéro local (ex. 777… → +221777…)
 POINTAGE_OTP_SMS_DEFAULT_CC=22177377724
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Soit un Messaging Service (recommandé pour l’A2P / expéditeurs multiples) :
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxx
# Soit un numéro Twilio expéditeur (E.164) :
# TWILIO_SMS_FROM=+15xxxxxxxxxx
# POINTAGE_OTP_SMS_HTTP_TIMEOUT=15
# Windows / cURL error 60 « unable to get local issuer certificate » : chemin absolu vers cacert.pem
# (télécharger https://curl.se/ca/cacert.pem) ou POINTAGE_OTP_SMS_HTTP_VERIFY=false (dev seulement)
# POINTAGE_OTP_SMS_HTTP_VERIFY=C:\chemin\vers\cacert.pem

# Centre d’urgence pointage : e-mails « Convoquer employé » / « Notifier RH »
# Liste d’e-mails RH (virgules). Obligatoire pour le bouton « Notifier RH ».
# POINTAGE_URGENCE_RH_EMAILS=rh1@example.com,rh2@example.com
# Forcer un mailer Laravel pour ces envois uniquement (ex. log en dev sans SMTP).
# POINTAGE_URGENCE_MAIL_MAILER=log
# Si SMTP échoue (ex. 535 Microsoft), retenter avec le mailer « log » (contenu dans storage/logs).
# Par défaut : true en local, false en prod (définissez explicitement pour forcer).
# POINTAGE_URGENCE_MAIL_FALLBACK_LOG=true

# E-mail OTP pointage : si SMTP global échoue, forcer le mailer « log » (code dans storage/logs)
# POINTAGE_OTP_MAIL_MAILER=log
# En local, secours log automatique si SMTP erreur (désactiver en prod : POINTAGE_OTP_EMAIL_FALLBACK_LOG=false)
# POINTAGE_OTP_EMAIL_FALLBACK_LOG=

# --- QR pointage site (impression agence) : contenu = URL scannable ---
# true = QR encode {APP_URL}/mobile/pointage/scan?t=… (false = jeton brut uniquement)
# Plages horaires pointage (détection auto arrivée / départ au scan)
# POINTAGE_PLAGE_ARRIVEE_DEBUT=07:00
# POINTAGE_PLAGE_ARRIVEE_FIN=12:00
# POINTAGE_PLAGE_DEPART_DEBUT=15:00
# POINTAGE_PLAGE_DEPART_FIN=20:00

# Jours où le QR est totalement désactivé (0=dim, 1=lun … 6=sam). Défaut : dimanche.
# POINTAGE_QR_INACTIF_JOURS=0
# Jours où le pointage est facultatif (QR actif, absences non comptées). Défaut : samedi.
# POINTAGE_QR_OPTIONNEL_JOURS=6

# POINTAGE_QR_ENCODE_AS_URL=true
# POINTAGE_QR_SCAN_URL=   # vide = {APP_URL}/mobile/pointage/scan
# POINTAGE_MOBILE_APP_SCHEME=cofipointe   # deep link : cofipointe://pointage/scan?t=…
# POINTAGE_GEOFENCING_ENABLED=true
# POINTAGE_DEFAULT_GEOFENCING_RADIUS=50
# Borne tablette : URL publique /pointage/kiosk/{token} (jeton par agence, généré à l’enrôlement)
# Ouvrir depuis Pointage → Sites → « Tablette » / « Copier lien ». TTL jeton dynamique = POINTAGE_QR_TTL.

# --- API PointRust (mobile) — préfixe /api : login, QR web, check-in/out, profil, notifications ---
# Base URL côté client : {APP_URL}/api (ex. https://votredomaine.com/api)
# JWT : définir un secret dédié en prod (min. 32 caractères) ; sinon dérivé de APP_KEY.
# POINTRUST_JWT_SECRET=
# POINTRUST_ACCESS_TTL=86400
# POINTRUST_REFRESH_TTL=2592000
# Si true : POST /login ne renvoie pas de token ; OTP puis POST /verify-otp (mailer MAIL_* ou log).
# POINTRUST_LOGIN_REQUIRES_OTP=false
# POINTRUST_OTP_TTL=300
# Durée du payload QR (secondes, plafonnée côté code à 120, défaut 60).
# POINTRUST_QR_TTL=60
# false = POST /register-device répond 404 (l’app mobile ignore silencieusement).
# POINTRUST_DEVICE_REGISTER=true
# Page WebView connexion JWT (même identifiants que le portail) : {APP_URL}/mobile/pointrust/login (alias /app/login)
# POINTRUST_MOBILE_WEB_LOGIN=true
# Redirection native optionnelle après login (sinon utiliser bridge JS : PointrustNative / ReactNativeWebView / Android)
# POINTRUST_MOBILE_NATIVE_SCHEME=pointrust